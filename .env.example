# === Aplicação ===
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# === Armazenamento de dados ===
DUCKDB_PATH=./data/copamind.duckdb

# === Qdrant (RAG) ===
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=copamind_knowledge

# === LM Studio (LLMs locais, API compatível com OpenAI) ===
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_TIMEOUT_SECONDS=300

# === Ollama (alternativa / embeddings) ===
OLLAMA_BASE_URL=http://localhost:11434

# === Chaves de APIs de dados (planos gratuitos; opcionais) ===
# Nunca versionar valores reais. Ver config/sources.example.yaml e DECISIONS ADR-0012.
FOOTBALL_DATA_ORG_API_KEY=
API_FOOTBALL_API_KEY=
ZAFRONIX_API_KEY=

# === Perfil de hardware (ver DECISIONS ADR-0003) ===
# 8gb  -> RTX 5070 Laptop, execução sequencial (default)
# 24gb -> servidor de IA, execução concorrente opt-in
HARDWARE_PROFILE=8gb

# === Modelos (IDs ficam em models.yaml; aqui apenas overrides opcionais) ===
MODEL_ANALYST_ID=
MODEL_CHALLENGER_ID=
MODEL_AUDITOR_ID=
EMBEDDING_MODEL_ID=

# === i18n ===
DEFAULT_LOCALE=pt-BR

# === Observabilidade ===
LOG_LEVEL=INFO
LOG_JSON=true

# === Política de snapshot ===
DEFAULT_SNAPSHOT_POLICY=latest_consistent
